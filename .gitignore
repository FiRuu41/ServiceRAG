# ──────────────────────────────────────────────
# Python 通用
# ──────────────────────────────────────────────

# 字节码缓存（Python 自动生成，每次运行都会更新，没有意义上传）
__pycache__/
*.py[cod]
*.pyo

# 虚拟环境（体积大，别人拿到代码后自己 pip install 就行）
.venv/
.venv-win/
venv/
ENV/

# pip 安装缓存
*.egg-info/
dist/
build/

# ──────────────────────────────────────────────
# IDE / 编辑器
# ──────────────────────────────────────────────

# PyCharm
.idea/

# VS Code
.vscode/

# ──────────────────────────────────────────────
# 项目特定：运行时生成的数据
# ──────────────────────────────────────────────

# Chroma 向量库（可以从文档重新生成，体积大）
chroma_db/

# 下载的 embedding 模型（体积几百MB，不应放在 git 里）
models/

# 日志文件
*.log
logs/

# ──────────────────────────────────────────────
# 敏感信息
# ──────────────────────────────────────────────

# .env 文件存放 API Key 等密钥，绝对不能上传
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────
# 知识库原始文档（企业内部资料，不应公开）
# 如果你的文档是公开的，把这行删掉就允许上传了
# ──────────────────────────────────────────────

data/raw/

# ──────────────────────────────────────────────
# 评估结果（运行评估脚本后生成的 CSV/JSON）
# 可以选择保留或忽略，看你自己需求
# ──────────────────────────────────────────────

evaluation/results/
py_file_order.md

